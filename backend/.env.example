# =============================================================================
# StoryPal Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# Application
APP_NAME="StoryPal"
APP_ENV=development  # development, staging, production
DEBUG=true
API_PREFIX=/api/v1

# Authentication
# Set to true for local development to skip Google SSO
DISABLE_AUTH=true

# JWT (REQUIRED in production — generate with: python -c 'import secrets; print(secrets.token_urlsafe(64))')
JWT_SECRET_KEY=your-secret-key-here

# Google OAuth 2.0 Credentials
GOOGLE_OAUTH_CLIENT_ID=your-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# OAuth Domain Restriction (comma-separated, leave empty to allow all)
ALLOWED_DOMAINS=

# Server
HOST=0.0.0.0
PORT=8888

# Database
DATABASE_URL=postgresql+asyncpg://storypal:storypal_dev@localhost:5432/storypal_dev
TEST_DATABASE_URL=postgresql+asyncpg://storypal:storypal_dev@localhost:5432/storypal_test

# Storage
STORAGE_TYPE=local  # local, gcs
STORAGE_PATH=./storage

# Google Cloud Storage (if STORAGE_TYPE=gcs)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCP_PROJECT_ID=your-project-id
AUDIO_BUCKET=storypal-audio

# Google Gemini API key (for LLM, TTS, Imagen, Live)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Gemini TTS Model Configuration
GEMINI_TTS_MODEL=gemini-2.5-pro-preview-tts
GEMINI_TTS_FALLBACK_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_PREVIEW_MODEL=gemini-2.5-flash-preview-tts

# Gemini TTS Quota
GEMINI_TTS_MAX_CONCURRENT=5
GEMINI_ESTIMATED_RPM=10

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
