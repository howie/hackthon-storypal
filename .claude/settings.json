{
  "permissions": {
    "allow": [
      "Bash(ruff *)",
      "Bash(python -m pytest *)",
      "Bash(pytest *)",
      "Bash(make *)",
      "Bash(cd * && ruff *)",
      "Bash(cd * && python -m pytest *)",
      "Bash(cd * && make *)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(cd * && npx tsc *)",
      "Bash(cd * && npx eslint *)",
      "Bash(git *)",
      "Bash(cd * && git *)",
      "Bash(uv *)",
      "Bash(cd * && uv *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(cd * && ls *)",
      "Bash(cd * && ls)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(docker *)",
      "Bash(cd * && docker *)",
      "Bash(gh *)",
      "Bash(cd * && gh *)",
      "Bash(npm *)",
      "Bash(cd * && npm *)",
      "Bash(npx *)",
      "Bash(cd * && npx *)",
      "Bash(bash *)",
      "Bash(cd * && bash *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-commit-check.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.specify/scripts/bash/cloud-init.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-check.sh"
          }
        ]
      }
    ]
  },
   "plugin:serena:serena": {
      "command": "uvx",
      "args": [
        "--from", "git+https://github.com/oraios/serena",
        "serena", "start-mcp-server",
        "--context", "claude-code",
        "--project-from-cwd"
      ]
    }

}
