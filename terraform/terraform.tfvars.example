# Copy to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars to version control.

project_id     = "your-gcp-project-id"
region         = "asia-east1"
domain         = "demo.heyuai.com.tw"
db_name        = "storypal"
db_user        = "storypal"
backend_image  = "asia-east1-docker.pkg.dev/YOUR_PROJECT/storypal/backend:latest"
frontend_image = "asia-east1-docker.pkg.dev/YOUR_PROJECT/storypal/frontend:latest"
